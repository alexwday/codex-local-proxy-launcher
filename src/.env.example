# Codex Local Proxy Launcher Configuration
# For a work machine that already has a working launcher .env, copy that file
# to src/.env first, then append the Codex override block from README.md.

# =============================================================================
# LOCAL PROXY AND CODEX DESKTOP SETTINGS
# =============================================================================

# Port for the local proxy/dashboard.
CODEX_PROXY_PORT=5051

# Host/interface to bind to. 127.0.0.1 is safest for local-only use.
BIND_HOST=127.0.0.1

# API key Codex Desktop uses when calling this local proxy.
# Leave empty to use ~/.codex/codex-launcher/proxy_token.
CODEX_PROXY_ACCESS_TOKEN=

# Optional dashboard API token. Defaults to CODEX_PROXY_ACCESS_TOKEN/proxy token.
CODEX_DASHBOARD_ACCESS_TOKEN=

# Flask session secret key for stable dashboard sessions.
FLASK_SECRET_KEY=

# User-level Codex state/config locations.
# CODEX_HOME defaults to ~/.codex.
CODEX_CONFIG_PATH=
CODEX_PROXY_TOKEN_FILE=
CODEX_PROVIDER_ID=codex-local-proxy
CODEX_PROVIDER_NAME=Codex Local Proxy
CODEX_APP_PATH=/Applications/Codex.app

# Apply ~/.codex/config.toml and restart/launch Codex Desktop on startup.
AUTO_APPLY_CODEX_CONFIG=true
AUTO_RESTART_CODEX_DESKTOP=true

# =============================================================================
# UPSTREAM OPENAI-COMPATIBLE ENDPOINT
# =============================================================================

# The direct upstream endpoint that receives model requests.
# Keep this as TARGET_ENDPOINT so existing launcher env files can be reused.
# Example: https://internal-llm.example.com/v1
TARGET_ENDPOINT=

# Upstream API shape.
# chat_completions translates Codex /v1/responses to upstream /v1/chat/completions.
# responses passes Codex /v1/responses through to upstream /v1/responses.
CODEX_UPSTREAM_WIRE_API=chat_completions

# Static upstream API key. Used only when OAuth is not configured.
TARGET_API_KEY=

# Set to true to return local Responses-shaped placeholder output.
USE_PLACEHOLDER_MODE=false

# Skip OAuth and use a mock upstream token. Useful only with placeholder mode
# or a development upstream that ignores bearer tokens.
DEV_MODE=false

# =============================================================================
# UPSTREAM OAUTH AUTHENTICATION
# =============================================================================

# OAuth 2.0 client-credentials auth for an internal endpoint.
# Leave empty to use TARGET_API_KEY instead. When OAuth is configured, it is
# preferred over static API-key auth.
OAUTH_TOKEN_ENDPOINT=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPE=
OAUTH_REFRESH_BUFFER_MINUTES=5

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Codex-facing model names exposed by GET /v1/models.
CODEX_MODEL_OPTIONS=gpt-5.5,gpt-5.4,gpt-5.4-mini,gpt-5.4-nano

# Optional mapping from Codex-facing model IDs to upstream/internal model IDs.
# Models not listed here pass through unchanged. On a work machine, copy this
# from the existing launcher env and make sure it includes CODEX_MODEL_OPTIONS.
#
# Format:
#   public-model=upstream-model,public-mini=upstream-mini
MODEL_MAPPING=gpt-5.5=,gpt-5.4=,gpt-5.4-mini=,gpt-5.4-nano=

# Optional pricing for dashboard display and session cost tracking.
# Format: model=input_cost_per_1k_tokens/output_cost_per_1k_tokens
MODEL_PRICING_USD_PER_1K=gpt-5.5=0/0,gpt-5.4=0/0,gpt-5.4-mini=0/0,gpt-5.4-nano=0/0

# Fallback model if a client request omits model.
CODEX_DEFAULT_MODEL=gpt-5.5

# If true, reject requests for model names not in CODEX_MODEL_OPTIONS.
STRICT_MODEL_ALLOWLIST=false

# Chat Completions upstream token limit behavior.
COMPLETION_TOKEN_LIMIT_FIELD=max_completion_tokens
CONVERT_MAX_TOKENS_TO_MAX_COMPLETION_TOKENS=true
INJECT_DEFAULT_MAX_COMPLETION_TOKENS=true
DEFAULT_MAX_COMPLETION_TOKENS=16384

# =============================================================================
# REQUEST BEHAVIOR
# =============================================================================

OPENAI_REQUEST_TIMEOUT_SECONDS=600
OPENAI_STREAMING_TIMEOUT_SECONDS=900

# Guard against identical concurrent in-flight requests.
ENABLE_DUPLICATE_REQUEST_GUARD=true
DUPLICATE_REQUEST_TTL_SECONDS=300

# Skip SSL certificate verification.
# rbc_security is optional; if unavailable, system certificate store is used.
SKIP_SSL_VERIFY=false

# Automatically open the dashboard in a browser on startup.
AUTO_OPEN_BROWSER=true
