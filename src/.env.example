# Kilo-Launcher Configuration
# Copy this file to .env and fill in your endpoint/auth values.

# =============================================================================
# LOCAL PROXY SETTINGS
# =============================================================================

# Port for the local proxy/dashboard.
PROXY_PORT=5050

# Host/interface to bind to. 127.0.0.1 is safest for local-only use.
BIND_HOST=127.0.0.1

# API key Kilo Code uses when calling this local proxy.
# Leave empty to auto-generate a random token on startup.
PROXY_ACCESS_TOKEN=

# Optional dashboard API token. Defaults to PROXY_ACCESS_TOKEN.
DASHBOARD_ACCESS_TOKEN=

# Flask session secret key for stable dashboard sessions.
FLASK_SECRET_KEY=

# =============================================================================
# UPSTREAM OPENAI-COMPATIBLE ENDPOINT
# =============================================================================

# The target endpoint that receives OpenAI Chat Completions requests.
# Examples:
#   https://api.openai.com/v1
#   https://internal-llm.example.com/v1
TARGET_ENDPOINT=https://api.openai.com/v1

# Static upstream API key. Used when OAuth is not configured.
TARGET_API_KEY=

# Set to true to return local OpenAI-shaped placeholder responses.
USE_PLACEHOLDER_MODE=false

# Skip OAuth and use a mock upstream token. Useful only with placeholder mode
# or a development upstream that ignores bearer tokens.
DEV_MODE=false

# =============================================================================
# UPSTREAM OAUTH AUTHENTICATION
# =============================================================================

# OAuth 2.0 client-credentials auth for an internal endpoint.
# Leave empty to use TARGET_API_KEY instead.
OAUTH_TOKEN_ENDPOINT=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPE=
OAUTH_REFRESH_BUFFER_MINUTES=5

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Kilo-facing model names exposed by GET /v1/models.
# These are the model IDs you select in Kilo Code.
MODEL_OPTIONS=gpt-5.4,gpt-5.4-mini,gpt-5.4-nano,gpt-5.2,gpt-5.1,gpt-5,gpt-5-mini,gpt-5-nano

# Optional mapping from Kilo-facing model IDs to upstream/internal model IDs.
# Models not listed here pass through unchanged.
#
# Format:
#   public-model=upstream-model,public-mini=upstream-mini
#
# Fill in the internal model IDs on the right side after copying this file.
# Blank right-hand sides are ignored, so models pass through unchanged until
# you fill them in.
MODEL_MAPPING=gpt-5.4=,gpt-5.4-mini=,gpt-5.4-nano=,gpt-5.2=,gpt-5.1=,gpt-5=,gpt-5-mini=,gpt-5-nano=

# Optional pricing for dashboard display and session cost tracking.
# Format: model=input_cost_per_1m_tokens/output_cost_per_1m_tokens
# Fill these with your internal chargeback/pricing values.
MODEL_PRICING_USD_PER_MILLION=gpt-5.4=0/0,gpt-5.4-mini=0/0,gpt-5.4-nano=0/0,gpt-5.2=0/0,gpt-5.1=0/0,gpt-5=0/0,gpt-5-mini=0/0,gpt-5-nano=0/0

# Fallback model if a client request omits model.
DEFAULT_MODEL=gpt-5.4

# If true, reject requests for model names not in MODEL_OPTIONS.
STRICT_MODEL_ALLOWLIST=false

# Convert Kilo's max_tokens field to max_completion_tokens before forwarding
# upstream. This avoids internal GPT-5-style endpoints falling back to a low
# default output cap, such as 400 tokens.
COMPLETION_TOKEN_LIMIT_FIELD=max_completion_tokens
CONVERT_MAX_TOKENS_TO_MAX_COMPLETION_TOKENS=true
INJECT_DEFAULT_MAX_COMPLETION_TOKENS=true
DEFAULT_MAX_COMPLETION_TOKENS=16384

# Backwards-compatible alias for copied cc-launcher configs. If
# DEFAULT_MAX_COMPLETION_TOKENS is set, it wins.
DEFAULT_MAX_TOKENS=16384

# Kilo model metadata used by the generated setup metadata.
KILO_PROVIDER_ID=openai-compatible
MODEL_CONTEXT_WINDOW=128000
MODEL_OUTPUT_TOKENS=16384
MODEL_SUPPORTS_TOOLS=true
MODEL_SUPPORTS_REASONING=true
MODEL_SUPPORTS_TEMPERATURE=false

# =============================================================================
# REQUEST BEHAVIOR
# =============================================================================

OPENAI_REQUEST_TIMEOUT_SECONDS=600
OPENAI_STREAMING_TIMEOUT_SECONDS=900

# Guard against identical concurrent in-flight requests.
ENABLE_DUPLICATE_REQUEST_GUARD=true
DUPLICATE_REQUEST_TTL_SECONDS=300

# Skip SSL certificate verification.
# rbc_security is optional; if unavailable, system certificate store is used.
SKIP_SSL_VERIFY=false

# Automatically open the dashboard in a browser on startup.
AUTO_OPEN_BROWSER=true
